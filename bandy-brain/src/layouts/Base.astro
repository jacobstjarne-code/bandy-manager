---
export interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const { title, description = 'Insikter om bandy från Bandy Manager — simuleringsbaserad analys.', noindex = true } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Bandy-Brain</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a href={`${base}/`} class="site-header__logo">
          <img src={`${base}/logo.svg`} alt="" width="28" height="28" class="site-header__logo-img" />
          Bandy-Brain
        </a>
        <nav>
          <ul class="site-header__nav">
            <li><a href={`${base}/findings/`} aria-current={Astro.url.pathname.startsWith(`${base}/findings`) ? 'page' : undefined}>Findings</a></li>
            <li><a href={`${base}/about/`} aria-current={Astro.url.pathname === `${base}/about/` ? 'page' : undefined}>Om</a></li>
            <li><a href={`${base}/ask/`} class="site-header__nav-cta">Ställ en fråga</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      Bandy-Brain — insikter ur Bandy Manager-simuleringar.
      Datan är offentlig, metoden är öppen, begränsningarna erkänns.
      <span class="site-footer__links">
        <a href={`${base}/bandy/`}>Källor om bandy</a>
        ·
        <a href={`${base}/spelet/`}>Om spelet</a>
      </span>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
