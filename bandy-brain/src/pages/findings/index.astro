---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Findings">
  <div class="page-container">
    <h1 style="font-family: var(--font-ui); font-size: 1.5rem; font-weight: 700; margin-bottom: 2rem;">
      Findings
    </h1>
    <p style="max-width: 560px; color: var(--color-muted); font-size: 0.95rem; margin-bottom: 2.5rem; font-family: var(--font-ui);">
      En finding är en rapport om ett specifikt fenomen i bandy — baserad på
      Bandygrytans verkliga matchdata och Bandy Managers simuleringsmotor.
      Varje finding har en fråga, en datakälla, ett fynd och en tolkning.
    </p>

    <ul class="findings-list">
      <li>
        <div class="finding-card">
          <p class="finding-card__number">Finding 004 · 25 april 2026</p>
          <h2 class="finding-card__title">
            <a href={`${base}/findings/004/`}>
              9,12 mål per match — bandy i ett målperspektiv
            </a>
          </h2>
          <p class="finding-card__excerpt">
            Bandy är en av de mest målrika lagsporterna med målvakt.
            Genomsnittlig målminut är 48,2 — nästan exakt halvtid — och
            54% av målen faller i andra halvlek. Vad berättar siffrorna
            om sportens karaktär?
          </p>
        </div>
      </li>
      <li>
        <div class="finding-card">
          <p class="finding-card__number">Finding 003 · 25 april 2026</p>
          <h2 class="finding-card__title">
            <a href={`${base}/findings/003/`}>
              Hemmafördelen i bandy är svagare än du tror
            </a>
          </h2>
          <p class="finding-card__excerpt">
            Hemmalaget vinner 50,2% av Elitseriematcherna — knappt över
            slumpen. I fotboll är motsvarande siffra ~60%, i ishockey ~55%.
            Varför är hemmafördelen så liten i bandy?
          </p>
        </div>
      </li>
      <li>
        <div class="finding-card">
          <p class="finding-card__number">Finding 002 · 25 april 2026</p>
          <h2 class="finding-card__title">
            <a href={`${base}/findings/002/`}>
              Hörnor är fem gånger mer värda i bandy än i fotboll
            </a>
          </h2>
          <p class="finding-card__excerpt">
            22,2% av alla mål i Elitserien kommer från hörnlägen.
            I fotboll är motsvarande siffra 4%. Skillnaden förklarar
            varför hörnan behandlas som ett centralt taktiskt vapen
            i bandy, inte en dödbolls-situation.
          </p>
        </div>
      </li>
      <li>
        <div class="finding-card">
          <p class="finding-card__number">Finding 001 · 25 april 2026</p>
          <h2 class="finding-card__title">
            <a href={`${base}/findings/001/`}>
              Halvtidsledning i bandy är starkare än i fotboll
            </a>
          </h2>
          <p class="finding-card__excerpt">
            Hur ofta vinner ett bandylag som leder vid halvtid? 78,1% visar
            verklig Elitseriedata från 907 matcher (Bandygrytan 2019–2026).
            Bandy Managers simuleringsmotor matchar med 77%.
          </p>
        </div>
      </li>
    </ul>
  </div>
</Base>
