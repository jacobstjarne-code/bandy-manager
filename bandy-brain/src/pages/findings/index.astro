---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const findings = [
      { num: '007', date: '25 april 2026', title: 'Dam vs herr: lika mål, men olika dynamik', excerpt: '' },
      { num: '006', date: '25 april 2026', title: 'Slutspelet: färre mål, starkare ledningar', excerpt: '' },
      { num: '005', date: '25 april 2026', title: 'Mål faller inte jämnt', excerpt: '' },
      { num: '004', date: '25 april 2026', title: 'Bandy och mål', excerpt: '' },
      { num: '003', date: '25 april 2026', title: 'Hemmafördelen i bandy', excerpt: '' },
      { num: '002', date: '25 april 2026', title: 'Hörnornas värde i bandy', excerpt: '' },
      { num: '001', date: '25 april 2026', title: 'Halvtidsledning i bandy', excerpt: '' },
];
---

<Base title="Findings">
  <div class="page-container">
    <h1 style="font-family: var(--font-ui); font-size: 1.5rem; font-weight: 700; margin-bottom: 2rem;">
      Findings
    </h1>
    <p style="max-width: 560px; color: var(--color-muted); font-size: 0.95rem; margin-bottom: 2.5rem; font-family: var(--font-ui);">
      En finding är en rapport om ett specifikt fenomen i bandy — baserad på
      Bandygrytans verkliga matchdata och Bandy Managers simuleringsmotor.
    </p>

    <ul class="findings-list">
      {findings.map(f => (
        <li>
          <div class="finding-card">
            <p class="finding-card__number">Finding {f.num} · {f.date}</p>
            <h2 class="finding-card__title">
              <a href={`${base}/findings/${f.num}/`}>{f.title}</a>
            </h2>
            <p class="finding-card__excerpt">{f.excerpt}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</Base>
